{
	"name": "lenevor/syscodes",
	"type": "project",
	"description": "The Lenevor Framework.",
	"keywords": ["syscodes","lenevor"],
	"license": "BSD-3-Clause",
	"homepage": "https://lenevor.com",
	"support": {
		"wiki": "https://github.com/lenevor/lenevor/wiki",
		"source": "https://github.com/lenevor"
	},
	"authors": [
		{
			"name": "Alexander Campo",
			"email": "jalexcam@gmail.com"
		}
	],
	"require": {
		"php": "^8.3",
		"ext-ctype": "*",
		"ext-filter": "*",
		"ext-hash": "*",
		"ext-mbstring": "*",
		"ext-openssl": "*",
		"ext-session": "*",
		"ext-tokenizer": "*",
		"nunomaduro/termwind": "^2.0",
		"psr/container": "^1.1.1 || ^2.0.1",
		"psr/log": "^1.0 || ^2.0 || ^3.0",
		"symfony/console": "^7.4.0 || ^8.0.0",
		"symfony/error-handler": "^7.4.0 || ^8.0.0",
		"symfony/http-foundation": "^7.4.0 || ^8.0.0",
		"symfony/http-kernel": "^7.4.0 || ^8.0.0",
		"symfony/process": "^7.4.0 || ^8.0.0",
		"symfony/routing": "^7.4.0 || ^8.0.0",
		"symfony/var-dumper": "^7.4.0 || ^8.0.0"
	},
	"require-dev": {
        "ext-gmp": "*",
        "predis/predis": "^2.3 || ^3.0"
    },
	"autoload": {
		"psr-4": {
			"Syscodes\\Components\\": "src/components/",
			"Syscodes\\Components\\Support\\": [
				"src/Components/Macroable/",
				"src/Components/Collections/"
			]
		},
		"files": [
			"src/components/Collections/Helpers.php",
			"src/components/Collections/functions.php",
			"src/components/Core/Helpers.php",
			"src/components/Filesystem/functions.php",
			"src/components/Support/Helpers.php",
			"src/components/Support/functions.php"
		]
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.9.x-dev"
        }
    },
	"minimum-stability": "dev",
	"prefer-stable": true
}